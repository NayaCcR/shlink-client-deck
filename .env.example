# Runtime UI config lives in public/config.json.
# Static Mode is the default and can be deployed as pure frontend assets.
NEXT_PUBLIC_APP_MODE=static

# Hosted Mode:
# NEXT_PUBLIC_APP_MODE=hosted
# AUTH_SECRET=replace-with-a-long-random-value
# SHLINK_CREDENTIAL_ENCRYPTION_KEY=replace-with-another-long-random-value
# LINK_CONSOLE_DATA_PATH=hosted-store.json

# Future production data layer:
# DATABASE_URL=postgresql://user:password@localhost:5432/link_console
# REDIS_URL=redis://localhost:6379
